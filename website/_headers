# Cloudflare Pages security headers.
# CSP is in REPORT-ONLY first (blocks nothing, logs violations). Watch the console
# in Incognito on the live site; once clean, rename the header to
# `Content-Security-Policy` (drop `-Report-Only`) to enforce — that also activates
# upgrade-insecure-requests + frame-ancestors, which are ignored in report-only.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self'; connect-src 'self'; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests
