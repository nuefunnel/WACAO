# Cloudflare Pages security headers.
# CSP is ENFORCED (verified clean in report-only first, console was clean on
# wacao.pages.dev 2026-06-19). The browser now refuses forbidden loads, and
# upgrade-insecure-requests + frame-ancestors are active. If you add new external
# resources (e.g. enabling Cloudflare Web Analytics needs static.cloudflareinsights.com
# in script-src + cloudflareinsights.com in connect-src), re-test in report-only first.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self'; connect-src 'self'; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests
